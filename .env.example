# Copy values into frontend/.env.local and backend/.env

# Backend origin for Next.js API proxy (server-side rewrites + SSR).
# Browser requests use same-origin /api/v1 — no cross-origin CORS required.
CHRONICLE_API_URL=http://localhost:8000

# Legacy fallback — prefer CHRONICLE_API_URL for new deployments.
NEXT_PUBLIC_API_URL=http://localhost:8000

CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# Backend Cognee Cloud settings — see backend/.env.example
